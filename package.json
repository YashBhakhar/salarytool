{
  "name": "salary-management-tool",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w api\" \"npm run dev -w web\"",
    "build": "npm run build -ws",
    "test": "npm run test -ws",
    "lint": "npm run lint -ws",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "prettier": "^3.8.3"
  }
}
